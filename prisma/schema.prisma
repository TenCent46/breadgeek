generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───

enum UserRole {
  TEACHER
  STUDENT
}

enum ServiceType {
  GROUP_LESSON
  MASTER_COURSE
  TRIAL_LESSON
}

enum ServiceStatus {
  PUBLISHED
  DRAFT
  ARCHIVED
}

enum BookingStatus {
  CONFIRMED
  PENDING
  CANCELLED
  COMPLETED
}

enum CustomerTier {
  REPEATER
  REGULAR
  TRIAL
  DORMANT
}

enum PaymentMethod {
  CREDIT_CARD
  BANK_TRANSFER
  CONVENIENCE_STORE
}

enum SaleStatus {
  COMPLETED
  REFUNDED
  PENDING
}

enum MessageChannel {
  EMAIL
  LINE
}

enum MessageStatus {
  SENT
  SCHEDULED
  DRAFT
}

enum IngredientCategory {
  FLOUR
  DAIRY
  FAT
  YEAST
  SUGAR
  SUB
  OTHER
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─── Auth.js Models ───

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?
  image         String?
  role          UserRole  @default(STUDENT)
  lineId        String?   @unique
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  school   School?
  customer Customer?
  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── School (multi-tenant root) ───

model School {
  id          String  @id @default(cuid())
  slug        String  @unique
  name        String
  description String?
  location    String?
  imageUrl    String?
  ownerId     String  @unique
  title       String  @default("")
  features    String  @default("")
  category    String  @default("パン教室")
  tags        String[]
  phone       String  @default("")
  themeType   String  @default("solid")
  themeColor  String  @default("#FFFFFF")
  instagram   String  @default("")
  x           String  @default("")
  youtube     String  @default("")
  line        String  @default("")
  tiktok             String  @default("")
  allowGuestBooking  Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner       User                  @relation(fields: [ownerId], references: [id])
  services    Service[]
  customers   Customer[]
  contacts    Contact[]
  messages    DistributionMessage[]
  ingredients Ingredient[]
  recipes     Recipe[]
  sales       SaleRecord[]
  settings    KitchenSettings?
  templates   MessageTemplate[]
}

// ─── Service ───

model Service {
  id             String        @id @default(cuid())
  schoolId       String
  type           ServiceType
  title          String
  description    String
  price          Int
  status         ServiceStatus @default(DRAFT)
  images         String[]
  capacity       Int?
  duration       Int?
  location       String?
  category       String
  linkedRecipeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school       School            @relation(fields: [schoolId], references: [id])
  linkedRecipe Recipe?           @relation(fields: [linkedRecipeId], references: [id], onDelete: SetNull)
  schedules    ServiceSchedule[]
  bookings     Booking[]
  reviews      Review[]
  sales        SaleRecord[]
}

model ServiceSchedule {
  id         String   @id @default(cuid())
  serviceId  String
  date       DateTime
  startTime  String
  endTime    String
  spotsTotal Int
  spotsTaken Int      @default(0)

  service Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
}

// ─── Customer ───

model Customer {
  id                 String       @id @default(cuid())
  schoolId           String
  userId             String?      @unique
  name               String
  email              String
  phone              String?
  tier               CustomerTier @default(TRIAL)
  totalSpent         Int          @default(0)
  visitCount         Int          @default(0)
  lastVisit          DateTime?
  registeredAt       DateTime     @default(now())
  tags               String[]
  notes              String       @default("")
  repeatRate         Float        @default(0)
  favoriteClassTypes String[]
  skillLevel         SkillLevel   @default(BEGINNER)

  school   School    @relation(fields: [schoolId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])
  bookings Booking[]
  reviews  Review[]

  @@unique([schoolId, email])
}

// ─── Booking ───

model Booking {
  id            String        @id @default(cuid())
  serviceId     String
  customerId    String
  scheduleId    String?
  participants  Int           @default(1)
  paymentType   String        @default("on_site")
  date          DateTime
  startTime  String
  endTime    String
  status     BookingStatus @default(PENDING)
  amount     Int
  notes      String        @default("")
  createdAt  DateTime      @default(now())

  service  Service  @relation(fields: [serviceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

// ─── Review ───

model Review {
  id         String    @id @default(cuid())
  serviceId  String
  customerId String
  rating     Int
  comment    String
  reply      String?
  repliedAt  DateTime?
  isPublished Boolean  @default(true)
  createdAt  DateTime  @default(now())

  service  Service  @relation(fields: [serviceId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])
}

// ─── Contact ───

model Contact {
  id           String    @id @default(cuid())
  schoolId     String
  name         String
  email        String
  source       String
  tags         String[]
  subscribedAt DateTime  @default(now())
  lastOpened   DateTime?

  school School @relation(fields: [schoolId], references: [id])
}

// ─── Message ───

model DistributionMessage {
  id             String        @id @default(cuid())
  schoolId       String
  subject        String
  content        String
  channel        MessageChannel
  status         MessageStatus @default(DRAFT)
  recipientCount Int           @default(0)
  openRate       Float?
  clickRate      Float?
  sentAt         DateTime?
  scheduledAt    DateTime?
  createdAt      DateTime      @default(now())

  school School @relation(fields: [schoolId], references: [id])
}

model MessageTemplate {
  id       String         @id @default(cuid())
  schoolId String
  type     String
  name     String
  subject  String
  content  String
  channel  MessageChannel

  school School @relation(fields: [schoolId], references: [id])
}

// ─── Sales ───

model SaleRecord {
  id             String        @id @default(cuid())
  schoolId       String
  serviceId      String?
  date           DateTime
  serviceName    String
  customerName   String
  paymentMethod  PaymentMethod
  amount         Int
  fee            Int
  netAmount      Int
  ingredientCost Int
  profit         Int
  profitMargin   Float
  status         SaleStatus    @default(COMPLETED)

  school  School   @relation(fields: [schoolId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
}

// ─── Recipe ───

model Recipe {
  id             String @id @default(cuid())
  schoolId       String
  name           String
  description    String
  servings       Int
  totalCost      Int
  costPerServing Int
  imageUrl       String?
  notes          String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school         School             @relation(fields: [schoolId], references: [id])
  ingredients    RecipeIngredient[]
  linkedServices Service[]
}

model RecipeIngredient {
  id            String @id @default(cuid())
  recipeId      String
  ingredientId  String
  quantityGrams Int

  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@unique([recipeId, ingredientId])
}

// ─── Ingredient ───

model Ingredient {
  id                    String             @id @default(cuid())
  schoolId              String
  name                  String
  currentStockGrams     Int
  unitCostPerKg         Int
  supplier              String
  reorderThresholdGrams Int
  category              IngredientCategory
  lastPurchasedAt       DateTime?
  costHistory           Json               @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school            School             @relation(fields: [schoolId], references: [id])
  recipeIngredients RecipeIngredient[]
}

// ─── Kitchen Settings ───

model KitchenSettings {
  id                       String @id @default(cuid())
  schoolId                 String @unique
  maxCapacity              Int    @default(8)
  defaultLessonDuration    Int    @default(150)
  ingredientReorderLeadDays Int   @default(3)
  defaultOverheadPerLesson Int    @default(2500)
  platformFeePercent       Float  @default(3.6)

  school School @relation(fields: [schoolId], references: [id])
}
